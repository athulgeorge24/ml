   "metadata": {},
   "outputs": [],
   "source": [
    "import numpy as np\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "7b88172a-6fa8-4b00-a1d7-6dcbd36bb364",
   "metadata": {},
   "outputs": [],
   "source": [
    "\n",
    "from sklearn.datasets import fetch_california_housing\n",
    "from sklearn.model_selection import train_test_split\n",
    "from sklearn.preprocessing import StandardScaler\n",
    "from sklearn.metrics import mean_squared_error, r2_score"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "a98e362c-d83a-4e78-b6e8-a004c3a20427",
   "metadata": {},
   "outputs": [],
   "source": [
    "#load dataset\n",
    "housing = fetch_california_housing()\n",
    "\n",
    "data = pd.DataFrame(housing.data,columns = housing.feature_names)\n",
    "data[\"Price\"] = housing.target"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "id": "df64842c-a32e-4dcb-a289-7f75b8d10ec1",
   "metadata": {},
   "outputs": [],
   "source": [
    "#select one feature\n",
    "x=data[[\"AveRooms\"]].values\n",
    "y=data['Price'].values"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "id": "95c7eb84-ff32-474a-a430-f926dfff5a8b",
   "metadata": {},
   "outputs": [],
   "source": [
    "#split data\n",
    "x_train,x_test, y_train,y_test = train_test_split(\n",
    "    x,y,\n",
    "    test_size = .3,\n",
    "    random_state = 19\n",
    ")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 6,
   "id": "d72f9aa9-6d19-483d-a190-33d91455f247",
   "metadata": {},
   "outputs": [],
   "source": [
    "#Feature Scaling\n",
    "\n",
    "scaler = StandardScaler()\n",
    "x_train_scaled = scaler.fit_transform(x_train)\n",
    "x_test_scaled = scaler.transform(x_test)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 45,
   "id": "3d33dd69-e7d7-413a-a1ff-77ed2fb3e92f",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Epoch 0, Cost =2.7977\n",
      "Epoch 100, Cost =0.9333\n",
      "Epoch 200, Cost =0.6835\n",
      "Epoch 300, Cost =0.6500\n",
      "Epoch 400, Cost =0.6455\n",
      "Epoch 500, Cost =0.6449\n",
      "Epoch 600, Cost =0.6448\n",
      "Epoch 700, Cost =0.6448\n",
      "Epoch 800, Cost =0.6448\n",
      "Epoch 900, Cost =0.6448\n"
     ]
    }
   ],
   "source": [
    "learning_rate = 0.01\n",
    "w =0\n",
    "b =0\n",
    "epochs = 1000\n",
    "\n",
    "n = len(x_train_scaled)\n",
    "cost_history = []\n",
    "for i in range(epochs):\n",
    "    y_pred = w * x_train_scaled.flatten() + b\n",
    "    dw = (1/n) * np.sum(((y_pred - y_train) * x_train_scaled.flatten()))\n",
    "    db = (1/n) * np.sum(y_pred - y_train)\n",
    "    w =w - learning_rate * dw\n",
    "    b =b - learning_rate * db\n",
    "    cost = (1/(2*n))*np.sum((y_pred - y_train) **2)\n",
    "    cost_history.append(cost)\n",
    "\n",
    "    if i % 100 ==0:\n",
    "        print(f\"Epoch {i}, Cost ={cost:.4f}\")\n",
    "\n",
    "\n",
    "y_pred_gd =w* x_test_scaled.flatten() + b"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 8,
   "id": "34fe1743-3443-4d55-915b-8c0827622dc9",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Gradient Descent\n",
      "--------------\n",
      "weight :  0.1893857445554625\n",
      "base :  2.066272547153559\n",
      "MSE :  1.3288018470171339\n",
      "R2 score  0.012509368400009269\n"
     ]
    }
   ],
   "source": [
    "print(\"Gradient Descent\")\n",
    "print(\"--------------\")\n",
    "print(\"weight : \",w)\n",
    "print(\"base : \",b)\n",
    "print(\"MSE : \",mean_squared_error(y_test,y_pred_gd))\n",
    "print(\"R2 score \", r2_score(y_test,y_pred_gd))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 39,
   "id": "2e96ec93-778b-465c-8ef8-1e3b50b8e547",
   "metadata": {},
   "outputs": [],
   "source": [
    "#Normal fumction\n",
    "\n",
    "\n",
    "x_train_ne = np.c_[np.ones((len(x_train),1)),x_train]\n",
    "x_test_ne = np.c_[np.ones((len(x_test),1)),x_test]\n",
    "\n",
    "\n",
    "theta = np.linalg.inv(x_train_ne.T @x_train_ne) @x_train_ne.T @ y_train\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 10,
   "id": "74797352-141c-4b20-9a95-04f53fe7835b",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "\n",
      " Normal Equations\n",
      "Intercept :  1.6298227565581056\n",
      "Intercept :  0.0805242156335707\n",
      "MSE 1.3288022750288873\n",
      "R2 score 0.012509050325800186\n"
     ]
    }
   ],
   "source": [
    "print(\"\\n Normal Equations\")\n",
    "print(\"Intercept : \",theta[0])\n",
    "print(\"Intercept : \",theta[1])\n",
    "print(\"MSE\",mean_squared_error(y_test,y_pred_ne))\n",
    "print(\"R2 score\",r2_score(y_test,y_pred_ne))\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 11,
   "id": "3f0b3a83-6b94-4aee-a8e6-0caec135713f",
   "metadata": {},
   "outputs": [],
   "source": [
    "#sort values for search regreesion line\n",
    "\n",
    "sort_axis =np.argsort(x_test.flatten())\n",
    "x_sorted = x_test[sort_axis]\n",
    "y_pred_ne_sorted = y_pred_ne[sort_axis]"
   ]
  },
